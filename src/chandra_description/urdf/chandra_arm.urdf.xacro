<?xml version="1.0" encoding="utf-8"?>
<robot name="chandra" xmlns:xacro="http://www.ros.org/wiki/xacro">
    <xacro:property name="effort" value="100"/>
    <xacro:property name="velocity" value="1"/>

    <!-- Useful Macros -->
    <xacro:macro name="default_inertial" params="mass">
        <inertial>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <mass value="${mass}" />
            <inertia ixx="1.0" ixy="0.0" ixz="0.0"
                     iyy="1.0" iyz="0.0"
                     izz="1.0" />
        </inertial>
    </xacro:macro>

    <!-- Include Gazebo Parameters -->
    <xacro:include filename="$(find chandra_description)/urdf/chandra_arm_gazebo.xacro" />

    <!-- Include ros2_control Plugins -->
    <xacro:include filename="$(find chandra_description)/urdf/chandra_arm_control.xacro" />

    <link name="base_link">
        <inertial>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <mass value="0.1"/>
            <inertia ixx="0.0001" ixy="0.0" ixz="0.0" iyy="0.0001" iyz="0.0" izz="0.0001"/>
        </inertial>
        <visual>
            <origin
                    xyz="0 0 0"
                    rpy="0 0 0"/>
            <geometry>
                <mesh
                        filename="file://$(find chandra_description)/meshes/base_link.STL"/>
            </geometry>
            <material
                    name="">
                <color
                        rgba="0.7 0.7 0.7 1"/>
            </material>
        </visual>
        <collision>
            <origin
                    xyz="0 0 0"
                    rpy="0 0 0"/>
            <geometry>
                <mesh
                        filename="file://$(find chandra_description)/meshes/base_link.STL"/>
            </geometry>
        </collision>
    </link>
    <link name="link1">
        <inertial>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <mass value="0.1"/>
            <inertia ixx="0.0001" ixy="0.0" ixz="0.0" iyy="0.0001" iyz="0.0" izz="0.0001"/>
        </inertial>
        <visual>
            <origin
                    xyz="0 0 0"
                    rpy="0 0 0"/>
            <geometry>
                <mesh
                        filename="file://$(find chandra_description)/meshes/link1.STL"/>
            </geometry>
            <material
                    name="">
                <color
                        rgba="0 0.7 0 1"/>
            </material>
        </visual>
        <collision>
            <origin
                    xyz="0 0 0"
                    rpy="0 0 0"/>
            <geometry>
                <mesh
                        filename="file://$(find chandra_description)/meshes/link1.STL"/>
            </geometry>
        </collision>
    </link>
    <joint name="joint1" type="revolute">
        <origin
                xyz="0 0 0.064"
                rpy="0 0 0"/>
        <parent
                link="base_link"/>
        <child
                link="link1"/>
        <axis
                xyz="0 0 1"/>
        <limit
                lower="-1.5708"
                upper="1.5708"
                effort="${effort}"
                velocity="${velocity}"/>
    </joint>
    <link name="link2">
        <inertial>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <mass value="0.1"/>
            <inertia ixx="0.0001" ixy="0.0" ixz="0.0" iyy="0.0001" iyz="0.0" izz="0.0001"/>
        </inertial>
        <visual>
            <origin
                    xyz="0 0 0"
                    rpy="0 0 0"/>
            <geometry>
                <mesh
                        filename="file://$(find chandra_description)/meshes/link2.STL"/>
            </geometry>
            <material
                    name="">
                <color
                        rgba="0.7 0.7 0.7 1"/>
            </material>
        </visual>
        <collision>
            <origin
                    xyz="0 0 0"
                    rpy="0 0 0"/>
            <geometry>
                <mesh
                        filename="file://$(find chandra_description)/meshes/link2.STL"/>
            </geometry>
        </collision>
    </link>
    <joint name="joint2" type="revolute">
        <origin
                xyz="0 0 0.0435"
                rpy="0 1.5708 0"/>
        <parent
                link="link1"/>
        <child
                link="link2"/>
        <axis
                xyz="0 0 1"/>
        <limit
                lower="-1.5708"
                upper="1.5708"
                effort="${effort}"
                velocity="${velocity}"/>
    </joint>
    <link name="link3">
        <inertial>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <mass value="0.1"/>
            <inertia ixx="0.0001" ixy="0.0" ixz="0.0" iyy="0.0001" iyz="0.0" izz="0.0001"/>
        </inertial>
        <visual>
            <origin
                    xyz="0 0 0"
                    rpy="0 0 0"/>
            <geometry>
                <mesh
                        filename="file://$(find chandra_description)/meshes/link3.STL"/>
            </geometry>
            <material
                    name="">
                <color
                        rgba="0 0.7 0 1"/>
            </material>
        </visual>
        <collision>
            <origin
                    xyz="0 0 0"
                    rpy="0 0 0"/>
            <geometry>
                <mesh
                        filename="file://$(find chandra_description)/meshes/link3.STL"/>
            </geometry>
        </collision>
    </link>
    <joint name="joint3" type="revolute">
        <origin
                xyz="-0.08285 0 0"
                rpy="0 0 0"/>
        <parent
                link="link2"/>
        <child
                link="link3"/>
        <axis
                xyz="0 0 1"/>
        <limit
                lower="-1.5708"
                upper="1.5708"
                effort="${effort}"
                velocity="${velocity}"/>
    </joint>
    <link name="link4">
        <inertial>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <mass value="0.1"/>
            <inertia ixx="0.0001" ixy="0.0" ixz="0.0" iyy="0.0001" iyz="0.0" izz="0.0001"/>
        </inertial>
        <visual>
            <origin
                    xyz="0 0 0"
                    rpy="0 0 0"/>
            <geometry>
                <mesh
                        filename="file://$(find chandra_description)/meshes/link4.STL"/>
            </geometry>
            <material
                    name="">
                <color
                        rgba="0.7 0.7 0.7 1"/>
            </material>
        </visual>
        <collision>
            <origin
                    xyz="0 0 0"
                    rpy="0 0 0"/>
            <geometry>
                <mesh
                        filename="file://$(find chandra_description)/meshes/link4.STL"/>
            </geometry>
        </collision>
    </link>
    <joint name="joint4" type="revolute">
        <origin
                xyz="-0.08285 0 0"
                rpy="0 0 0"/>
        <parent
                link="link3"/>
        <child
                link="link4"/>
        <axis
                xyz="0 0 1"/>
        <limit
                lower="-1.5708"
                upper="1.5708"
                effort="${effort}"
                velocity="${velocity}"/>
    </joint>
    <link name="link5">
        <inertial>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <mass value="0.1"/>
            <inertia ixx="0.0001" ixy="0.0" ixz="0.0" iyy="0.0001" iyz="0.0" izz="0.0001"/>
        </inertial>
        <visual>
            <origin
                    xyz="0 0 0"
                    rpy="0 0 0"/>
            <geometry>
                <mesh
                        filename="file://$(find chandra_description)/meshes/link5.STL"/>
            </geometry>
            <material
                    name="">
                <color
                        rgba="1 1 1 1"/>
            </material>
        </visual>
        <collision>
            <origin
                    xyz="0 0 0"
                    rpy="0 0 0"/>
            <geometry>
                <mesh
                        filename="file://$(find chandra_description)/meshes/link5.STL"/>
            </geometry>
        </collision>
    </link>
    <joint name="joint5" type="revolute">
        <origin
                xyz="-0.07385 -0.00215 0"
                rpy="0 -1.5708 0"/>
        <parent
                link="link4"/>
        <child
                link="link5"/>
        <axis
                xyz="0 0 1"/>
        <limit
                lower="-1.5708"
                upper="3.1416"
                effort="${effort}"
                velocity="${velocity}"/>
    </joint>
    <link name="gripper_right">
        <xacro:default_inertial mass="0.01"/>
        <visual>
            <origin
                    xyz="0 0 0"
                    rpy="0 0 0"/>
            <geometry>
                <mesh filename="file://$(find chandra_description)/meshes/gripper_right_finger.STL"/>
            </geometry>
        </visual>
        <collision>
            <origin
                    xyz="0 0 0"
                    rpy="0 0 0"/>
            <geometry>
                <mesh filename="file://$(find chandra_description)/meshes/gripper_right_finger.STL"/>
            </geometry>
        </collision>
    </link>
    <joint name ="joint_6" type="revolute">
        <parent link="link5"/>
        <child link = "gripper_right"/>
        <origin
                xyz="0 0 0"
                rpy="0 0 0"/>
        <axis xyz="0 0 1"/>
        <limit lower="-${PI / 2}" upper="0.0" 
               effort="${effort}" velocity="${velocity}"/>
    </joint>
    <link name="gripper_left">
        <xacro:default_inertial mass="0.01"/>
        <visual>
            <origin
                    xyz="0 0 0"
                    rpy="0 0 0"/>
            <geometry>
                <mesh filename="file://$(find chandra_description)/meshes/gripper_left_finger.STL"/>
            </geometry>
        </visual>
        <collision>
            <origin
                    xyz="0 0 0"
                    rpy="0 0 0"/>
            <geometry>
                <mesh filename="file://$(find chandra_description)/meshes/gripper_left_finger.STL"/>
            </geometry>
        </collision>
    </link>
    <joint name ="joint_7" type="revolute">
        <parent link="link5"/>
        <child link = "gripper_left"/>
        <origin
                xyz="0 0 0"
                rpy="0 0 0"/>
        <axis xyz="0 0 1"/>
        <limit lower="0.0" upper="${PI / 2}" 
               effort="${effort}" velocity="${velocity}"/>
        <mimic joint="joint_6" multiplier="-1"/>
    </joint>
</robot>