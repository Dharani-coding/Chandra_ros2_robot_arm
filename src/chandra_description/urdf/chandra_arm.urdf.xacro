<?xml version="1.0" encoding="utf-8"?>
<robot name="chandra" xmlns:xacro="http://www.ros.org/wiki/xacro">
        <!-- Color Properties -->
        <xacro:property name="deep_blue" value="0.0 0.0 0.6 1"/>
        <xacro:property name="green" value="0.0 0.7 0.0 1"/>
        <xacro:property name="black" value="0.05 0.05 0.05 1"/>
        <!-- Macro for metallic material -->
        <xacro:macro name="metallic_material" params="name colour">
                <material name="${name}">
                        <color rgba="${colour}"/>
                        <specular value="0.8 0.8 0.8 1"/>
                </material>
        </xacro:macro>
        <!-- Xacro Properties for common values -->
        <xacro:property name="default_colour" value="0.7 0.7 0.7 1"/>
        <xacro:property name="default_scale" value="1 1 1"/>
    <xacro:property name="effort" value="100"/>
    <xacro:property name="velocity" value="1"/>

    <!-- Useful Macros -->
    <xacro:macro name="default_inertial" params="mass">
        <inertial>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <mass value="${mass}" />
            <inertia ixx="1.0" ixy="0.0" ixz="0.0"
                     iyy="1.0" iyz="0.0"
                     izz="1.0" />
        </inertial>
    </xacro:macro>

    <xacro:arg name="is_sim" default="False"/>

    <!-- Include Gazebo Parameters -->
    <xacro:include filename="$(find chandra_description)/urdf/chandra_arm_gazebo.xacro" />

    <!-- Include ros2_control Plugins -->
    <xacro:include filename="$(find chandra_description)/urdf/chandra_arm_control.xacro" />

    <link name="world"/>
    <joint name="virtual_joint" type="fixed">
        <parent link="world"/>
        <child link="base_link"/>
        <origin xyz="0 0 0" rpy="0 0 0"/>
    </joint> 
    <link name="base_link">
        <xacro:default_inertial mass="10.0"/>
        <visual>
                <origin xyz="0 0 0" rpy="0 0 0"/>
                <geometry>
                        <mesh filename="file://$(find chandra_description)/meshes/base_link.STL" scale="${default_scale}"/>
                </geometry>
                <xacro:metallic_material name="base_link_material" colour="${deep_blue}"/>
        </visual>
        <collision>
            <origin
                    xyz="0 0 0"
                    rpy="0 0 0"/>
            <geometry>
                <mesh
                        filename="file://$(find chandra_description)/meshes/base_link.STL" scale="${default_scale}"/>
            </geometry>
        </collision>
    </link>
    <link name="link1">
        <xacro:default_inertial mass="2.0"/>
        <visual>
                <origin xyz="0 0 0" rpy="0 0 0"/>
                <geometry>
                        <mesh filename="file://$(find chandra_description)/meshes/link1.STL" scale="${default_scale}"/>
                </geometry>
                <xacro:metallic_material name="link1_material" colour="${green}"/>
        </visual>
        <collision>
            <origin
                    xyz="0 0 0"
                    rpy="0 0 0"/>
            <geometry>
                <mesh
                        filename="file://$(find chandra_description)/meshes/link1.STL" scale="${default_scale}"/>
            </geometry>
        </collision>
    </link>
    <joint name="joint1" type="revolute">
        <origin
                xyz="0 0 0.064"
                rpy="0 0 0"/>
        <parent
                link="base_link"/>
        <child
                link="link1"/>
        <axis
                xyz="0 0 1"/>
        <limit
                lower="-1.5708"
                upper="1.5708"
                effort="${effort}"
                velocity="${velocity}"/>
    </joint>
    <link name="link2">
        <xacro:default_inertial mass="1.5"/>
        <visual>
                <origin xyz="0 0 0" rpy="0 0 0"/>
                <geometry>
                        <mesh filename="file://$(find chandra_description)/meshes/link2.STL" scale="${default_scale}"/>
                </geometry>
                <xacro:metallic_material name="link2_material" colour="${deep_blue}"/>
        </visual>
        <collision>
            <origin
                    xyz="0 0 0"
                    rpy="0 0 0"/>
            <geometry>
                <mesh
                        filename="file://$(find chandra_description)/meshes/link2.STL" scale="${default_scale}"/>
            </geometry>
        </collision>
    </link>
    <joint name="joint2" type="revolute">
        <origin
                xyz="0 0 0.0435"
                rpy="0 1.5708 0"/>
        <parent
                link="link1"/>
        <child
                link="link2"/>
        <axis
                xyz="0 0 1"/>
        <limit
                lower="-1.5708"
                upper="1.5708"
                effort="${effort}"
                velocity="${velocity}"/>
    </joint>
    <link name="link3">
        <xacro:default_inertial mass="1.0"/>
        <visual>
                <origin xyz="0 0 0" rpy="0 0 0"/>
                <geometry>
                        <mesh filename="file://$(find chandra_description)/meshes/link3.STL" scale="${default_scale}"/>
                </geometry>
                <xacro:metallic_material name="link3_material" colour="${green}"/>
        </visual>
        <collision>
            <origin
                    xyz="0 0 0"
                    rpy="0 0 0"/>
            <geometry>
                <mesh
                        filename="file://$(find chandra_description)/meshes/link3.STL" scale="${default_scale}"/>
            </geometry>
        </collision>
    </link>
    <joint name="joint3" type="revolute">
        <origin
                xyz="-0.08285 0 0"
                rpy="0 0 0"/>
        <parent
                link="link2"/>
        <child
                link="link3"/>
        <axis
                xyz="0 0 1"/>
        <limit
                lower="-1.5708"
                upper="1.5708"
                effort="${effort}"
                velocity="${velocity}"/>
    </joint>
    <link name="link4">
        <xacro:default_inertial mass="0.7"/>
        <visual>
                <origin xyz="0 0 0" rpy="0 0 0"/>
                <geometry>
                        <mesh filename="file://$(find chandra_description)/meshes/link4.STL" scale="${default_scale}"/>
                </geometry>
                <xacro:metallic_material name="link4_material" colour="${deep_blue}"/>
        </visual>
        <collision>
            <origin
                    xyz="0 0 0"
                    rpy="0 0 0"/>
            <geometry>
                <mesh
                        filename="file://$(find chandra_description)/meshes/link4.STL" scale="${default_scale}"/>
            </geometry>
        </collision>
    </link>
    <joint name="joint4" type="revolute">
        <origin
                xyz="-0.08285 0 0"
                rpy="0 0 0"/>
        <parent
                link="link3"/>
        <child
                link="link4"/>
        <axis
                xyz="0 0 1"/>
        <limit
                lower="-1.5708"
                upper="1.5708"
                effort="${effort}"
                velocity="${velocity}"/>
    </joint>
    <link name="link5">
        <xacro:default_inertial mass="0.5"/>
        <visual>
                <origin xyz="0 0 0" rpy="0 0 0"/>
                <geometry>
                        <mesh filename="file://$(find chandra_description)/meshes/link5.STL" scale="${default_scale}"/>
                </geometry>
                <xacro:metallic_material name="link5_material" colour="${deep_blue}"/>
        </visual>
        <collision>
            <origin
                    xyz="0 0 0"
                    rpy="0 0 0"/>
            <geometry>
                <mesh
                        filename="file://$(find chandra_description)/meshes/link5.STL" scale="${default_scale}"/>
            </geometry>
        </collision>
    </link>
    <joint name="joint5" type="revolute">
        <origin
                xyz="-0.07385 -0.00215 0"
                rpy="0 -1.5708 0"/>
        <parent
                link="link4"/>
        <child
                link="link5"/>
        <axis
                xyz="0 0 1"/>
        <limit
                lower="-1.5708"
                upper="3.1416"
                effort="${effort}"
                velocity="${velocity}"/>
    </joint>
    <link name="gripper_right">
        <xacro:default_inertial mass="0.01"/>
        <visual>
                <origin xyz="0.0121 0 -0.0335" rpy="0 0 0"/>
                <geometry>
                        <mesh filename="file://$(find chandra_description)/meshes/gripper_right_finger.STL" scale="${default_scale}"/>
                </geometry>
                <xacro:metallic_material name="gripper_right_material" colour="${black}"/>
        </visual>
        <collision>
            <origin
                    xyz="0.0121 0 -0.0335"
                    rpy="0 0 0"/>
            <geometry>
                <mesh filename="file://$(find chandra_description)/meshes/gripper_right_finger.STL" scale="${default_scale}"/>
            </geometry>
        </collision>
    </link>
    <joint name ="joint6" type="revolute">
        <parent link="link5"/>
        <child link = "gripper_right"/>
        <origin
                xyz="-0.0121 0 0.0335"
                rpy="0 0 0"/>
        <axis xyz="0 1 0"/>
        <limit lower="-${PI / 2}" upper="0.0" 
               effort="${effort}" velocity="${velocity}"/>
    </joint>
    <link name="gripper_left">
        <xacro:default_inertial mass="0.01"/>
        <visual>
                <origin xyz="-0.0121 0 -0.0335" rpy="0 0 0"/>
                <geometry>
                        <mesh filename="file://$(find chandra_description)/meshes/gripper_left_finger.STL" scale="${default_scale}"/>
                </geometry>
                <xacro:metallic_material name="gripper_left_material" colour="${black}"/>
        </visual>
        <collision>
            <origin
                    xyz="-0.0121 0 -0.0335"
                    rpy="0 0 0"/>
            <geometry>
                <mesh filename="file://$(find chandra_description)/meshes/gripper_left_finger.STL" scale="${default_scale}"/>
            </geometry>
        </collision>
    </link>
    <joint name ="joint7" type="revolute">
        <parent link="link5"/>
        <child link = "gripper_left"/>
        <origin
                xyz="0.0121 0 0.0335"
                rpy="0 0 0"/>
        <axis xyz="0 1 0"/>
        <limit lower="0.0" upper="${PI / 2}" 
               effort="${effort}" velocity="${velocity}"/>
        <mimic joint="joint6" multiplier="-1"/>
    </joint>
</robot>